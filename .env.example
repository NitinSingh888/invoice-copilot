# Invoice Copilot — environment configuration (copy to .env). All vars are optional;
# sensible defaults let the app run key-free on SQLite with zero setup.

# --- Database ---------------------------------------------------------------
# Default (zero-setup): a local SQLite file.
IC_DATABASE_URL=sqlite:///./invoice_copilot.db
# Local Postgres (via `docker compose up -d postgres`):
# IC_DATABASE_URL=postgresql+psycopg://copilot:copilot@localhost:5432/copilot
# Production (Neon free Postgres) — paste your connection string, add the psycopg driver:
# IC_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DBNAME?sslmode=require

# --- LLM provider -----------------------------------------------------------
# mock = fully deterministic, NO API keys needed (default; used for tests + the demo).
# anthropic | openai | auto (failover across whatever keys are set, ending in mock).
IC_LLM_PROVIDER=mock
# IC_ANTHROPIC_API_KEY=sk-ant-...
# IC_OPENAI_API_KEY=sk-...
# IC_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# IC_OPENAI_MODEL=gpt-4o

# --- Policy / autonomy knobs (optional) -------------------------------------
# IC_T_AMOUNT=10000
# IC_TOLERANCE_PCT=0.05
# IC_LEARN_MIN_CORRECTIONS=3
# IC_DUPLICATE_WINDOW_DAYS=14
# IC_COLD_START_N=2
