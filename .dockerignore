# Version control
.git
.github

# Python virtual environment (never copy the host venv into the image)
**/.venv
venv

# Node deps (installed inside the container by npm ci)
**/node_modules

# Built frontend (rebuilt inside the container)
**/dist

# Byte-compiled files and caches
**/__pycache__
*.py[cod]
*.egg-info

# Tool caches
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache

# Test suite (not needed in prod)
backend/tests

# Docs
docs

# Local secrets
**/.env

# Markdown files
*.md

# OS / editor noise
.DS_Store
.idea
.vscode
